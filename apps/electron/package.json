{
  "name": "@fileterm/electron",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "description": "Modern remote workspace for SSH, SFTP, and FTP.",
  "author": "St0ff3l",
  "scripts": {
    "predev": "npm --prefix ../.. run sync:version",
    "prebuild": "npm --prefix ../.. run sync:version",
    "pretypecheck": "npm --prefix ../.. run sync:version",
    "prepackage:mac": "npm --prefix ../.. run sync:version",
    "prepackage:win": "npm --prefix ../.. run sync:version",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:update-test": "FILETERM_LOCAL_UPDATE=1 npm run dev",
    "dev:renderer": "vite",
    "predev:main": "node ./scripts/clean-dist-electron.mjs",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on tcp:5189 file:dist-electron/main/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "prebuild:main": "node ./scripts/clean-dist-electron.mjs",
    "build:main": "tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "npm run test:unit && npm run test:controllers",
    "test:unit": "node --test --experimental-strip-types test/transfers/*.test.ts test/system-metrics/*.test.ts test/profiles/*.test.ts test/ssh-keys/*.test.ts test/workspace/*.test.ts test/config/*.test.ts",
    "pretest:controllers": "npm --prefix ../.. run build -w @fileterm/core && npm run build:main",
    "test:controllers": "node --test test/controllers/*.test.mjs",
    "test:transfers": "node --test --experimental-strip-types test/transfers/*.test.ts",
    "test:transfers:protocol": "npm --prefix ../.. run build -w @fileterm/core && npm run build:main && node --test test/protocol/*.test.mjs",
    "clean:release": "node ./scripts/clean-release.mjs",
    "package:mac": "electron-builder --mac --arm64",
    "package:update-test:mac": "electron-builder --config electron-builder.update-test.yml --mac --arm64",
    "package:update-test:win": "electron-builder --config electron-builder.update-test.yml --win --x64",
    "release:mac": "npm run build && npm run package:mac",
    "package:win": "electron-builder --win --x64",
    "release:win": "npm run build && npm run package:win"
  },
  "dependencies": {
    "@fileterm/core": "2.0.0",
    "@fileterm/shared": "2.0.0",
    "@fileterm/storage": "2.0.0",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "basic-ftp": "^6.0.1",
    "electron-updater": "^6.8.3",
    "iconv-lite": "0.7.2",
    "monaco-editor": "0.53.0",
    "opencc-js": "1.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serialport": "^13.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "42.4.0",
    "electron-builder": "^26.15.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.fileterm.desktop",
    "productName": "FileTerm",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "St0ff3l",
        "repo": "fileterm"
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/**",
      "package.json",
      "!**/sshcrypto.node"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "FileTerm-${version}-macos-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FileTerm-${version}-windows-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "FileTerm-${version}-windows-${arch}-portable.${ext}"
    }
  }
}
