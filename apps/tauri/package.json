{
  "name": "@fileterm/tauri",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "description": "Modern remote workspace for SSH, SFTP, and FTP.",
  "author": "St0ff3l",
  "scripts": {
    "predev": "npm --prefix ../.. run sync:version",
    "prebuild": "npm --prefix ../.. run sync:version",
    "pretypecheck": "npm --prefix ../.. run sync:version",
    "prepackage:mac": "npm --prefix ../.. run sync:version",
    "prepackage:win": "npm --prefix ../.. run sync:version",
    "dev": "node ./scripts/run-tauri.mjs dev",
    "dev:renderer": "vite",
    "build": "node ./scripts/run-tauri.mjs build",
    "build:renderer": "vite build",
    "build:main": "node ./scripts/run-tauri.mjs build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1",
    "clean:release": "node ./scripts/clean-release.mjs",
    "release:mac": "node ./scripts/run-tauri.mjs build --target aarch64-apple-darwin --config src-tauri/tauri.release.macos.conf.json",
    "release:mac:x64": "node ./scripts/run-tauri.mjs build --target x86_64-apple-darwin --config src-tauri/tauri.release.macos.conf.json",
    "release:win": "node ./scripts/run-tauri.mjs build --target x86_64-pc-windows-msvc --config src-tauri/tauri.release.windows.conf.json"
  },
  "dependencies": {
    "@fileterm/core": "2.0.2",
    "@fileterm/shared": "2.0.2",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@tauri-apps/api": "^2.5.0",
    "monaco-editor": "0.53.0",
    "opencc-js": "1.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@tauri-apps/cli": "^2.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
