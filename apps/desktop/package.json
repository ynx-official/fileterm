{
  "name": "@termdock/desktop",
  "version": "0.3.0-beta.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "description": "Modern remote workspace for SSH, SFTP, and FTP.",
  "author": "St0ff3l",
  "scripts": {
    "predev": "npm --prefix ../.. run sync:version",
    "prebuild": "npm --prefix ../.. run sync:version",
    "pretypecheck": "npm --prefix ../.. run sync:version",
    "prepackage:mac": "npm --prefix ../.. run sync:version",
    "prepackage:win": "npm --prefix ../.. run sync:version",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on tcp:5188 file:dist-electron/main/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "clean:release": "node ./scripts/clean-release.mjs",
    "package:mac": "electron-builder --mac --arm64",
    "release:mac": "npm run build && npm run package:mac",
    "package:win": "electron-builder --win --x64",
    "release:win": "npm run build && npm run package:win"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@termdock/core": "0.3.0-beta.1",
    "@termdock/shared": "0.3.0-beta.1",
    "@termdock/storage": "0.3.0-beta.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "basic-ftp": "^6.0.1",
    "iconv-lite": "0.7.2",
    "monaco-editor": "0.55.1",
    "opencc-js": "1.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "42.4.0",
    "electron-builder": "^26.15.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.termdock.desktop",
    "productName": "TermDock",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "TermDock-${version}-macos-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "TermDock-${version}-windows-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "TermDock-${version}-windows-${arch}-portable.${ext}"
    }
  }
}
