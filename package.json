{
  "name": "termdock",
  "version": "0.1.0-beta.9",
  "private": true,
  "license": "MIT",
  "description": "Modern remote workspace for SSH, SFTP, and FTP.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @termdock/desktop",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "release:mac": "npm run release:mac -w @termdock/desktop",
    "release:win": "npm run release:win -w @termdock/desktop",
    "postinstall": "node ./vendor/cpu-features-shim/apply-shim.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "electron": "^42.4.0"
  }
}
